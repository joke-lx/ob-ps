{
  "name": "obsidian-local-runner",
  "version": "1.0.0",
  "description": "Obsidian sidebar that runs local commands (e.g. npm run dev) and streams output.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs --production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "terminal",
    "process",
    "sidebar"
  ],
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.23.0",
    "obsidian": "^1.4.16",
    "typescript": "^5.5.3"
  }
}
