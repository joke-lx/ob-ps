{
  "name": "obsidian-local-runner",
  "version": "1.0.0",
  "description": "Obsidian sidebar that runs local commands (e.g. npm run dev) and streams output.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs --production",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "plugin",
    "terminal",
    "process",
    "sidebar"
  ],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.10",
    "esbuild": "^0.23.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "^1.4.16",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.1"
  }
}
